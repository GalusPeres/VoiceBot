# Discord Bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
BOT_USERNAME=VoiceBot

# Port für Botboard-API
BOT_API_PORT=3003

# Botboard-Token (muss mit Botboard-Wert übereinstimmen)
BOT_API_TOKEN=

# URLs der anderen Bots
MUSIC_BOT_URL=http://localhost:3001
SOUND_BOT_URL=http://localhost:3002

# Verhalten
COMMAND_PREFIX=.
MENTION_ONLY=false
CONTROL_CHANNEL_ID=

# Daten-Ordner (auf Unraid: gemounteter Pfad)
DATA_DIR=/data

# Modelle (werden beim ersten Start automatisch heruntergeladen)
WHISPER_MODEL=small
# LLM_MODEL_PATH wird automatisch auf DATA_DIR/models/llm/Qwen3.5-2B-Q4_K_M.gguf gesetzt

# Piper TTS (wird im Docker-Image mitgeliefert)
PIPER_BIN=/app/piper/piper
# PIPER_MODEL_PATH wird automatisch auf DATA_DIR/models/tts/de_DE-thorsten-medium.onnx gesetzt
